---
interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <nav>
      <div class="container nav-inner">
        <a href="/scheduled-db/" class="logo">
          <div class="logo-icon">
            <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
              <circle cx="16" cy="16" r="14" fill="none" stroke="url(#logo-grad)" stroke-width="2.5"/>
              <circle cx="16" cy="10" r="3" fill="#fbbf24"/>
              <circle cx="10" cy="20" r="2.5" fill="#3b82f6"/>
              <circle cx="22" cy="20" r="2.5" fill="#3b82f6"/>
              <line x1="16" y1="13" x2="10" y2="18" stroke="#22d3ee" stroke-width="1.5" opacity="0.7"/>
              <line x1="16" y1="13" x2="22" y2="18" stroke="#22d3ee" stroke-width="1.5" opacity="0.7"/>
              <line x1="10" y1="20" x2="22" y2="20" stroke="#a78bfa" stroke-width="1" stroke-dasharray="2,2" opacity="0.5"/>
              <defs>
                <linearGradient id="logo-grad" x1="0" y1="0" x2="32" y2="32">
                  <stop offset="0%" stop-color="#22d3ee"/>
                  <stop offset="100%" stop-color="#a78bfa"/>
                </linearGradient>
              </defs>
            </svg>
          </div>
          <span class="logo-text">Scheduled<span class="logo-highlight">-DB</span></span>
        </a>
        <div class="nav-links">
          <a href="#features" class="nav-link">Features</a>
          <a href="#architecture" class="nav-link">Architecture</a>
          <a href="#quickstart" class="nav-link">Quick Start</a>
          <a href="#api" class="nav-link">API</a>
          <a href="https://github.com/manudiv16/scheduled-db" target="_blank" rel="noopener" class="nav-github">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
        </div>
      </div>
    </nav>
    <slot />
    <footer>
      <div class="container">
        <div class="footer-links">
          <a href="https://github.com/manudiv16/scheduled-db">GitHub</a>
          <a href="https://raft.github.io/">Raft Consensus</a>
          <a href="https://prometheus.io/">Prometheus</a>
          <a href="https://opentelemetry.io/">OpenTelemetry</a>
        </div>
        <p>Built with HashiCorp Raft, Gorilla Mux, Robfig Cron, Prometheus & OpenTelemetry</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
