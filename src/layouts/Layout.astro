---
interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@600;700&family=IBM+Plex+Sans:wght@400;500;600&family=JetBrains+Mono:wght@400;500;700&family=VT323&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <!-- HUD Navbar -->
    <nav class="hud-nav">
      <div class="container nav-inner">
        <a href="/scheduled-db/" class="logo">
          <div class="logo-icon">
            <svg width="24" height="24" viewBox="0 0 32 32" fill="none" stroke="var(--neon-cyan)">
              <!-- Simplified Timing Wheel + Cluster logo -->
              <circle cx="16" cy="16" r="14" stroke-width="2" stroke-dasharray="4 2"/>
              <circle cx="16" cy="16" r="8" stroke-width="1"/>
              <circle cx="16" cy="16" r="2" fill="var(--neon-cyan)"/>
              <line x1="16" y1="16" x2="16" y2="4" stroke-width="2"/>
            </svg>
          </div>
          <span class="logo-text neon-text-cyan">SCHEDULED-DB</span>
        </a>
        <div class="nav-links">
          <div class="nav-status">
            <span class="status-dot anim-blink"></span>
            <span class="hud-text">SYSTEM ONLINE</span>
          </div>
          <a href="#features" class="nav-link hud-text">FEATURES</a>
          <a href="#architecture" class="nav-link hud-text">ARCHITECTURE</a>
          <a href="#roadmap" class="nav-link hud-text">ROADMAP</a>
          <a href="#quickstart" class="nav-link hud-text">QUICK START</a>
          <a href="#api" class="nav-link hud-text">API</a>
          <a href="https://github.com/manudiv16/scheduled-db" target="_blank" rel="noopener" class="nav-github">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
        </div>
      </div>
    </nav>
    
    <main>
      <slot />
    </main>

    <!-- Boot-log style footer -->
    <footer class="hud-footer">
      <div class="container footer-inner">
        <div class="footer-ascii">
          <pre class="hud-text">
    [LEADER]
       |
  +----+----+
  |         |
[F1]      [F2]
          </pre>
        </div>
        <div class="footer-log hud-text">
          <p>> BOOT_SEQ: COMPLETE</p>
          <p>> CONSENSUS: HASHICORP_RAFT</p>
          <p>> METRICS: PROMETHEUS + OTEL</p>
          <p>> SCHEDULING: HIERARCHICAL_TIMING_WHEEL</p>
          <div class="footer-links">
            <a href="https://github.com/manudiv16/scheduled-db">[ GITHUB ]</a>
            <a href="https://raft.github.io/">[ RAFT ]</a>
            <a href="https://prometheus.io/">[ PROMETHEUS ]</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  /* Basic layout styles that don't belong in base.css */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--spacing-lg);
  }

  .hud-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 48px;
    background: rgba(4, 6, 12, 0.9);
    border-bottom: 1px solid var(--border-hud);
    z-index: 100;
    backdrop-filter: blur(8px);
  }

  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 100%;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .logo-text {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
  }

  .nav-status {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    color: var(--phosphor);
  }

  .status-dot {
    width: 8px;
    height: 8px;
    background-color: var(--phosphor);
    border-radius: 50%;
    box-shadow: var(--glow-phosphor);
  }

  .nav-link {
    color: var(--ink-secondary);
  }

  .nav-link:hover {
    color: var(--neon-cyan);
    text-shadow: var(--glow-cyan-sm);
  }

  .nav-github {
    color: var(--ink-secondary);
  }

  .nav-github:hover {
    color: var(--ink-primary);
  }

  main {
    padding-top: 48px; /* offset for nav */
  }

  .hud-footer {
    border-top: 1px solid var(--border-hud);
    background: var(--bg-panel);
    padding: var(--spacing-xl) 0;
    margin-top: var(--spacing-2xl);
  }

  .footer-inner {
    display: flex;
    gap: var(--spacing-2xl);
    align-items: flex-start;
  }

  .footer-ascii pre {
    color: var(--neon-cyan);
    opacity: 0.6;
    line-height: 1.2;
  }

  .footer-log {
    color: var(--ink-secondary);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .footer-links {
    margin-top: var(--spacing-md);
    display: flex;
    gap: var(--spacing-md);
  }
</style>