---
import Navbar from '../components/Navbar.svelte';
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <Navbar client:load />
    <slot />
    <footer class="border-t border-brand-border py-10 text-center text-sm text-brand-text-muted">
      <div class="mx-auto max-w-7xl px-4 sm:px-6">
        <div class="mb-4 flex flex-wrap items-center justify-center gap-6">
          <a href="https://github.com/manudiv16/scheduled-db" class="text-brand-text-secondary transition-colors hover:text-brand-cyan">GitHub</a>
          <a href="https://raft.github.io/" class="text-brand-text-secondary transition-colors hover:text-brand-cyan">Raft Consensus</a>
          <a href="https://prometheus.io/" class="text-brand-text-secondary transition-colors hover:text-brand-cyan">Prometheus</a>
          <a href="https://opentelemetry.io/" class="text-brand-text-secondary transition-colors hover:text-brand-cyan">OpenTelemetry</a>
        </div>
        <p>Built with HashiCorp Raft, Gorilla Mux, Robfig Cron, Prometheus & OpenTelemetry</p>
      </div>
    </footer>
  </body>
</html>
