---
import Layout from '../layouts/Layout.astro';
import HeroConsole from '../components/sections/HeroConsole.svelte';
import FeaturesBento from '../components/sections/FeaturesBento.svelte';
import ArchitectureLive from '../components/sections/ArchitectureLive.svelte';
import RoadmapTrack from '../components/sections/RoadmapTrack.svelte';
import QuickStartTerminal from '../components/sections/QuickStartTerminal.svelte';
import ApiMonitor from '../components/sections/ApiMonitor.astro';
---

<Layout title="Scheduled-DB - Distributed Job Scheduling">
	<main>
    <!-- client:load: Immediate hydration for boot sequence -->
		<HeroConsole client:load />
    
    <!-- client:visible: Defer hydration until scrolled into view -->
		<FeaturesBento client:visible />
		
    <!-- client:visible: Heavy SVG + animations, defer -->
    <ArchitectureLive client:visible />
		
    <!-- client:visible: Interactive timeline, defer -->
    <RoadmapTrack client:visible />
		
    <!-- client:idle: Interactive but not critical for initial paint -->
    <QuickStartTerminal client:idle />
		
    <!-- Static Astro component (No JS) -->
    <ApiMonitor />
	</main>
</Layout>

<style>
	main {
		width: 100%;
    color: var(--ink-primary);
	}
</style>
